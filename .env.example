# Devin org API credentials
DEVIN_API_TOKEN=cog_replace_me
DEVIN_ORG_ID=org_replace_me

# Use the exact repo identifier Devin expects in the "repos" array.
# This is the connected GitHub repo Devin should work in.
DEVIN_REPOS=owner/repo-name

# Optional Devin overrides
DEVIN_PLAYBOOK_ID=
DEVIN_BYPASS_APPROVAL=false
DEVIN_MAX_ACU_LIMIT=

# Local Gitea settings
GITEA_BASE_URL=http://127.0.0.1:3000
GITEA_TOKEN=
GITEA_WEBHOOK_SECRET=replace_with_random_secret
TRIGGER_LABEL=devin-autostart

# Bridge server settings
HOST=127.0.0.1
PORT=3001
HTTP_TIMEOUT_MS=10000
POLL_INTERVAL_MS=20000
STATE_FILE=bridge-runtime/state.json
